&lt;br&gt;
&lt;div align=&#34;center&#34; style=&#34;font-size: 12px; color: blue; font-weight: bold;&#34;&gt;
  &lt;img src=&#34;https://origin.picgo.net/2025/12/14/-5302d380b1640d8b.md.png&#34;&gt;
